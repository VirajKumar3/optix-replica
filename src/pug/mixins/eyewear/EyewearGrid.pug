mixin EyewearCard(product, index)
  .eyewear-card-wrapper.animate-on-scroll(
    style=`transition-delay: ${index * 0.1}s`
    data-product-id=`${product.brand}-${product.image}`
    data-product-image=product.image
    data-product-brand=product.brand
    data-product-price=product.price
    data-product-original-price=product.originalPrice
    data-product-discount=product.discount
  )
    .card.eyewear-card.h-100.border-0
      .eyewear-img-container
        img.card-img-top(src=`${CWD}assets/img/gallery/${product.image}` alt=product.brand)
      .card-body.pb-0
        p.product-brand= product.brand
        .price-section
          span.current-price= `₹${product.price}`
          span.original-price= `₹${product.originalPrice}`
        p.discount-badge= `${product.discount}% OFF`
      .card-footer.eyewear-card-footer.bg-transparent.border-0.pt-0.pb-4.px-3
        .d-flex.align-items-center.gap-2
          button.btn.btn-dark.flex-grow-1.buy-now-btn BUY NOW
          button.btn.btn-fav
            i(data-feather="heart")

mixin CategoryGrid(title, products)
  section.eyewear-section
    .container
      .eyewear-header
        nav(aria-label="breadcrumb")
          ol.breadcrumb
            li.breadcrumb-item: a(href="index.html") Home
            li.breadcrumb-item.active(aria-current="page")= title
        h2.eyewear-title= title
      
      .eyewear-grid(data-category=title.toLowerCase().replace(/\s/g, ''))
        each product, index in products
          +EyewearCard(product, index)

