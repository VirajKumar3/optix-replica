mixin ExclusiveCollection
  section.py-0
    .container-fluid.px-0
      .row.g-0
        .col-md-5.bg-dark.text-white.p-5.p-lg-10.d-flex.flex-column.justify-content-center
          div(style="max-width: 500px; margin: 0 auto;")
            h6.text-primary.fw-bold.ls-2.mb-3 VIRTUAL EXPERIENCE
            h2.display-3.fw-bold.mb-4.text-white Virtual Try-On Zone
            p.lead.text-400.mb-6 See how any frame looks on your face in real-time. Our advanced AR technology brings the showroom to your home. Try on 500+ styles instantly.
            .d-grid.gap-3.d-sm-flex
              a.btn.btn-lg.btn-primary.px-5.rounded-0(href="#!" role="button") Start Try-On
              a.btn.btn-lg.btn-outline-light.px-5.rounded-0(href="#!" role="button") How it Works
        .col-md-7
          .card.card-span.h-100.border-0.rounded-0
            img.card-img.h-100(src=`${CWD}assets/img/gallery/virtual-try-on.png` style="object-fit: cover; min-height: 700px;" alt="Virtual Try-On")